# Local database used by Prisma. Replace with your own MongoDB URL if needed.
DATABASE_URL="mongodb://localhost:27017/editron"

# Local-only placeholder. Replace with a long random value before using auth flows.
AUTH_SECRET="replace-this-with-a-long-random-value-for-local-dev"

# Optional OAuth credentials. Leave blank unless you are testing provider sign-in.
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional AI provider fallback keys. Users can also provide keys in the UI.
GEMINI_API_KEY=""
GROQ_API_KEY=""
MISTRAL_API_KEY=""

# Optional local collaboration settings. Defaults are used when these are unset.
NEXT_PUBLIC_COLLAB_SERVER_URL=""
COLLAB_PORT="1234"

# Optional NextAuth helpers for local/deployed URL and trusted-host behavior.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=""

# Optional deploy-only platform tokens. Leave blank for normal local development.
VERCEL_MASTER_TOKEN=""
NETLIFY_MASTER_TOKEN=""
